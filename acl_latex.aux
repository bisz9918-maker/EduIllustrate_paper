\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Overview of the EduIllustrate system. Given a K-12 STEM problem, the EduIllustrate Agent generates a structured explanation document through a four-stage pipeline. The resulting output is evaluated using an 8-dimension rubric validated against human expert raters via both automated LLM-as-judge and human evaluation protocols.}}{4}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:framework}{{2}{4}{Overview of the EduIllustrate system. Given a K-12 STEM problem, the EduIllustrate Agent generates a structured explanation document through a four-stage pipeline. The resulting output is evaluated using an 8-dimension rubric validated against human expert raters via both automated LLM-as-judge and human evaluation protocols}{figure.caption.1}{}}
